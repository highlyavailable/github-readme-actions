{
  "name": "github-readme-actions",
  "version": "2.0.0",
  "description": "OSS contributor dashboard action: live PR, review, and activity sections in any markdown file.",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "ncc build index.js -o dist --source-map --license licenses.txt",
    "clean": "rm -rf dist/ node_modules/ coverage/",
    "dev": "npm run lint && npm run test && npm run build",
    "ci": "npm run lint && npm run test && npm run build",
    "release:patch": "npm version patch --no-git-tag-version",
    "release:minor": "npm version minor --no-git-tag-version",
    "release:major": "npm version major --no-git-tag-version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/highlyavailable/github-readme-actions.git"
  },
  "keywords": [
    "github",
    "action",
    "readme",
    "dashboard",
    "pull-requests",
    "code-review",
    "open-source",
    "automation",
    "github-actions"
  ],
  "author": "Peter Bryant",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/rest": "^20.0.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  }
}
